# Lightweight test image — does NOT include nginx, Node.js, or frontend
FROM python:3.13-slim

WORKDIR /app

# Install prod deps + test deps
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt pytest httpx

# Copy only what pytest needs
COPY main.py expense_classifier.py database.py ./
COPY models/ ./models/
COPY routes/ ./routes/
COPY tests/ ./tests/
COPY prompts/ ./prompts

CMD ["pytest", "tests/", "-v", "--tb=short"]
